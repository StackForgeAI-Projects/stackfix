# Database
DATABASE_URL="postgresql://stackfix:stackfix_dev@localhost:5432/stackfix?schema=public"

# Redis (Phase 8+ queues)
REDIS_URL="redis://localhost:6379"

# JWT — generate secure secrets for production (min 64 chars)
JWT_SECRET="dev-jwt-secret-change-in-production-minimum-sixty-four-characters-long!!"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-minimum-sixty-four-characters!!"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3001"
WEB_URL="http://localhost:3001"

# Email — optional in dev (logs to console without SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="StackFix <noreply@stackfix.app>"
# Sender for customer-facing notifications (invoices, status updates, payments)
NOTIFICATIONS_EMAIL_FROM="StackFix <notifications@stackfix.app>"

# MTN MoMo (Phase 8)
MTN_MOMO_API_KEY=""
MTN_MOMO_SUBSCRIPTION_KEY=""
MTN_MOMO_TARGET_ENVIRONMENT="sandbox"
MTN_MOMO_CALLBACK_URL="http://localhost:4000/api/v1/webhooks/momo-payment"

# WhatsApp Cloud API (Meta) — customer notifications. Empty = dev log mode.
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v21.0"
# SMS (next phase)
SMS_API_KEY=""
SMS_SENDER_ID="STACKFIX"

# PDF
PUPPETEER_EXECUTABLE_PATH=""

# Translation (googletrans Python service — required for Kinyarwanda/French in dev & prod)
# Dev: http://localhost:5001  |  Prod: internal URL e.g. http://stackfix-translate:5001
# Start: docker compose up -d translate  —  See docs/PRODUCTION.md
TRANSLATE_SERVICE_URL="http://localhost:5001"
