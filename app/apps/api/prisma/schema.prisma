// StackFix Database Schema — SOP v1.0 Phase 4

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentModel {
  pay_before
  pay_on_pickup
}

enum OrganisationPlan {
  starter
  growth
  enterprise
}

enum Language {
  en
  rw
  fr
}

enum UserRole {
  super_admin
  admin
  technician
}

enum TicketStatus {
  pending
  under_repair
  completed
  picked_up
  cancelled
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

enum InvoiceStatus {
  draft
  sent
  paid
  partially_paid
  overdue
  cancelled
}

enum LineItemType {
  part
  labour
  diagnostic
  other
}

enum PaymentMethod {
  momo_ussd
  cash
  card
  other
  airtel_money
}

enum PaymentRecordStatus {
  pending
  successful
  failed
  reversed
}

enum NotificationChannel {
  whatsapp
  sms
  email
}

enum NotificationStatus {
  pending
  sent
  delivered
  failed
}

enum StatusChangeTrigger {
  manual
  system
  payment_confirmation
}

enum StaffMessageRequestType {
  general
  edit_ticket
  delete_ticket
}

enum StaffMessageStatus {
  open
  resolved
}

enum UserNotificationType {
  message_new
  message_reply
  message_resolved
  ticket_status
  ticket_created
  invoice_created
  invoice_paid
  team_member
  system
}

enum ActivityAction {
  login
  ticket_created
  ticket_updated
  ticket_status_changed
  ticket_deleted
  ticket_note_added
  invoice_created
  invoice_sent
  invoice_paid
  invoice_updated
  invoice_deleted
  user_created
  user_updated
  user_deleted
  user_access_changed
  org_updated
  message_sent
  message_replied
  message_resolved
}

model Organisation {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String         @db.VarChar(255)
  slug           String         @unique @db.VarChar(100)
  address        String?        @db.Text
  phone          String?        @db.VarChar(20)
  email          String?        @db.VarChar(255)
  logoUrl        String?        @map("logo_url") @db.Text
  rdbNumber      String?        @map("rdb_number") @db.VarChar(50)
  paymentModel   PaymentModel   @default(pay_on_pickup) @map("payment_model")
  defaultVatRate Decimal        @default(18.00) @map("default_vat_rate") @db.Decimal(5, 2)
  language       Language       @default(en)
  momoAccountId  String?        @map("momo_account_id") @db.VarChar(255)
  bankName          String?     @map("bank_name") @db.VarChar(255)
  bankAccountName   String?     @map("bank_account_name") @db.VarChar(255)
  bankAccountNumber String?     @map("bank_account_number") @db.VarChar(50)
  plan           OrganisationPlan @default(starter)
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  users         User[]
  customers     Customer[]
  tickets       Ticket[]
  invoices      Invoice[]
  payments      Payment[]
  notifications Notification[]
  ticketCounters TicketCounter[]
  staffMessages StaffMessage[]
  userNotifications UserNotification[]
  activityLogs      ActivityLog[]

  @@map("organisations")
}

model TicketCounter {
  organisationId String @id @map("organisation_id") @db.Uuid
  lastNumber     Int    @default(0) @map("last_number")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@map("ticket_counters")
}

model InvoiceCounter {
  organisationId String @id @map("organisation_id") @db.Uuid
  lastNumber     Int    @default(0) @map("last_number")

  @@map("invoice_counters")
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId String    @map("organisation_id") @db.Uuid
  fullName       String    @map("full_name") @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  phone          String?   @db.VarChar(20)
  passwordHash   String    @map("password_hash") @db.Text
  role           UserRole
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organisation   Organisation @relation(fields: [organisationId], references: [id])
  assignedTickets Ticket[]    @relation("AssignedTechnician")
  createdTickets  Ticket[]    @relation("CreatedByUser")
  statusChanges  TicketStatusHistory[]
  notes          TicketNote[]
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  staffMessagesSent StaffMessage[] @relation("StaffMessageSender")
  staffMessagesResolved StaffMessage[] @relation("StaffMessageResolver")
  userNotifications UserNotification[]
  activityLogs      ActivityLog[]

  @@index([organisationId])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Customer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId String   @map("organisation_id") @db.Uuid
  fullName       String   @map("full_name") @db.VarChar(255)
  phone          String   @db.VarChar(20)
  email          String?  @db.VarChar(255)
  totalRepairs   Int      @default(0) @map("total_repairs")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id])
  tickets      Ticket[]
  invoices     Invoice[]
  notifications Notification[]

  @@index([organisationId, phone])
  @@map("customers")
}

model Ticket {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId      String         @map("organisation_id") @db.Uuid
  ticketNumber        String         @map("ticket_number") @db.VarChar(20)
  customerId          String         @map("customer_id") @db.Uuid
  technicianId        String?        @map("technician_id") @db.Uuid
  createdByUserId     String?        @map("created_by_user_id") @db.Uuid
  deviceType          String         @map("device_type") @db.VarChar(100)
  deviceBrand         String?        @map("device_brand") @db.VarChar(100)
  deviceModel         String?        @map("device_model") @db.VarChar(100)
  faultDescription    String         @map("fault_description") @db.Text
  internalNotes       String?        @map("internal_notes") @db.Text
  status              TicketStatus   @default(pending)
  priority            TicketPriority @default(normal)
  estimatedCompletion DateTime?      @map("estimated_completion") @db.Date
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organisation   Organisation @relation(fields: [organisationId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])
  technician     User?        @relation("AssignedTechnician", fields: [technicianId], references: [id])
  createdBy      User?        @relation("CreatedByUser", fields: [createdByUserId], references: [id])
  invoice        Invoice?
  statusHistory  TicketStatusHistory[]
  notes          TicketNote[]
  notifications  Notification[]
  staffMessages  StaffMessage[]

  @@unique([organisationId, ticketNumber])
  @@index([organisationId, status])
  @@index([organisationId, createdAt(sort: Desc)])
  @@index([organisationId, createdByUserId])
  @@map("tickets")
}

model TicketNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_notes")
}

model TicketStatusHistory {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId        String              @map("ticket_id") @db.Uuid
  fromStatus      TicketStatus?       @map("from_status")
  toStatus        TicketStatus        @map("to_status")
  changedByUserId String?             @map("changed_by_user_id") @db.Uuid
  trigger         StatusChangeTrigger @default(manual)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User?  @relation(fields: [changedByUserId], references: [id])

  @@index([ticketId])
  @@map("ticket_status_history")
}

model Invoice {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId String        @map("organisation_id") @db.Uuid
  ticketId       String        @unique @map("ticket_id") @db.Uuid
  invoiceNumber  String        @map("invoice_number") @db.VarChar(20)
  customerId     String        @map("customer_id") @db.Uuid
  subtotal       Decimal       @db.Decimal(12, 2)
  vatRate        Decimal       @default(18.00) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount      Decimal       @map("vat_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency       String        @default("RWF") @db.Char(3)
  status         InvoiceStatus @default(draft)
  ussdCode       String?       @map("ussd_code") @db.VarChar(100)
  ussdReference  String?       @map("ussd_reference") @db.VarChar(100)
  dueDate        DateTime?     @map("due_date") @db.Date
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz(6)
  pdfUrl         String?       @map("pdf_url") @db.Text
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id])
  ticket       Ticket       @relation(fields: [ticketId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  lineItems    InvoiceLineItem[]
  payments     Payment[]

  @@unique([organisationId, invoiceNumber])
  @@index([organisationId, status])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String       @map("invoice_id") @db.Uuid
  description String       @db.Text
  quantity    Decimal      @default(1) @db.Decimal(8, 2)
  unitPrice   Decimal      @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal      @map("total_price") @db.Decimal(12, 2)
  itemType    LineItemType @default(labour) @map("item_type")
  sortOrder   Int          @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model Payment {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId    String              @map("organisation_id") @db.Uuid
  invoiceId         String              @map("invoice_id") @db.Uuid
  amount            Decimal             @db.Decimal(12, 2)
  currency          String              @default("RWF") @db.Char(3)
  paymentMethod     PaymentMethod       @map("payment_method")
  momoTransactionId String?             @map("momo_transaction_id") @db.VarChar(255)
  momoPayerMsisdn   String?             @map("momo_payer_msisdn") @db.VarChar(20)
  status            PaymentRecordStatus @default(pending)
  confirmedAt       DateTime?           @map("confirmed_at") @db.Timestamptz(6)
  notes             String?             @db.Text
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id])
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([organisationId, confirmedAt(sort: Desc)])
  @@map("payments")
}

model Notification {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId    String             @map("organisation_id") @db.Uuid
  ticketId          String?            @map("ticket_id") @db.Uuid
  customerId        String?            @map("customer_id") @db.Uuid
  channel           NotificationChannel
  messageBody       String             @map("message_body") @db.Text
  status            NotificationStatus @default(pending)
  providerMessageId String?            @map("provider_message_id") @db.VarChar(255)
  sentAt            DateTime?          @map("sent_at") @db.Timestamptz(6)
  deliveredAt       DateTime?          @map("delivered_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id])
  ticket       Ticket?      @relation(fields: [ticketId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])

  @@map("notifications")
}

model StaffMessage {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId String                  @map("organisation_id") @db.Uuid
  senderId       String                  @map("sender_id") @db.Uuid
  ticketId       String?                 @map("ticket_id") @db.Uuid
  parentId       String?                 @map("parent_id") @db.Uuid
  requestType    StaffMessageRequestType @default(general) @map("request_type")
  subject        String                  @db.VarChar(255)
  body           String                  @db.Text
  status         StaffMessageStatus      @default(open)
  resolvedById   String?                 @map("resolved_by_id") @db.Uuid
  resolvedAt     DateTime?               @map("resolved_at") @db.Timestamptz(6)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation  @relation(fields: [organisationId], references: [id])
  sender       User          @relation("StaffMessageSender", fields: [senderId], references: [id])
  ticket       Ticket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  parent       StaffMessage? @relation("StaffMessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies      StaffMessage[] @relation("StaffMessageThread")
  resolvedBy   User?         @relation("StaffMessageResolver", fields: [resolvedById], references: [id])

  @@index([organisationId, status, createdAt(sort: Desc)])
  @@index([organisationId, senderId])
  @@index([parentId])
  @@map("staff_messages")
}

model UserNotification {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId String               @map("organisation_id") @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  type           UserNotificationType
  title          String               @db.VarChar(255)
  body           String               @db.Text
  href           String?              @db.VarChar(500)
  readAt         DateTime?            @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("user_notifications")
}

model ActivityLog {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisationId String         @map("organisation_id") @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  action         ActivityAction
  metadata       Json           @default("{}")
  href           String?        @db.VarChar(500)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  organisation Organisation @relation(fields: [organisationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organisationId, createdAt(sort: Desc)])
  @@index([organisationId, userId])
  @@map("activity_logs")
}
